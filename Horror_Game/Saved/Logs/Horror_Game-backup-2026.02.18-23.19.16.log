[2026.02.18-23.17.05:658][157]LogFabLauncher: Debug payload: [{"id":"a9ea4ed3-9499-4ff7-8f95-833611933167","path":"C:/ProgramData/Epic/EpicGamesLauncher/VaultCache/FabLibrary/the_little_house_in_the_woods_Low-poly_3D_model-a9ea4ed3/fbx","meshes":[{"file":"C:/ProgramData/Epic/EpicGamesLauncher/VaultCache/FabLibrary/the_little_house_in_the_woods_Low-poly_3D_model-a9ea4ed3/fbx/la_petite_maison_dans_les_bois.fbx","name":"","material_index":-1,"lods":[]}],"materials":[],"native_files":[],"additional_textures":[],"metadata":{"launcher":{"version":"0.0.1","listening_port":24563},"fab":{"assetNamespace":"","listing":{"averageRating":0,"createdAt":"","description":"<p>The Wooden Log Cabin is a detailed forest house 3D model, perfect for game environments, survival scenes, or cinematic productions. Inspired by classic wilderness lodges, this cabin is ideal for horror, adventure, or peaceful countryside projects.</p><p>Features</p><p>Detailed wooden log structure with porch and stone chimney</p><p>Optimized for games (game-ready topology)</p><p>PBR 4K Textures (Wood, Roof Shingles, Stone, Ground)</p><p>Includes interior volume (basic) ready to be detailed or furnished</p><p>Perfect for Unreal Engine, Unity, Blender, Maya, 3ds Max</p><p>Technical Details</p><p>Formats included: .fbx, .obj, .blend,</p><p>Textures: 4K (Base Color, Normal, Roughness, Ambient Occlusion)</p><p>Scale: Real-world units, optimized for game engines</p><p>Ready for: video games, VR/AR, rendering, cinematic projects</p><p>Use cases</p><p>Survival games (forest, zombie, or apocalyptic setting)</p><p>Adventure / open world projects</p><p>Horror scenes (classic “cabin in the woods” look)</p><p>Cinematic cutscenes</p><p>Architectural visualization with rustic style</p>","isAiForbidden":true,"isAiGenerated":false,"lastUpdatedAt":"","listingType":"3d-model","media":"https://media.fab.com/image_previews/gallery_images/62cba276-1860-4220-8881-0e6ad17a3e1f/905a5735-c390-4b86-b684-36be71afc5c5.png","publishedAt":"2